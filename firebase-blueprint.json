{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application (student or teacher).",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier of the user."
        },
        "name": {
          "type": "string",
          "description": "The name of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the user."
        },
        "role": {
          "type": "string",
          "enum": ["student", "teacher"],
          "description": "The role of the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the user was created."
        }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Session": {
      "title": "Session",
      "description": "A tutoring session for a math problem.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this session."
        },
        "studentName": {
          "type": "string",
          "description": "The name of the student."
        },
        "problemDescription": {
          "type": "string",
          "description": "A description of the math problem."
        },
        "status": {
          "type": "string",
          "enum": ["in-progress", "completed"],
          "description": "The status of the session."
        },
        "startTime": {
          "type": "string",
          "format": "date-time",
          "description": "The time the session started."
        },
        "endTime": {
          "type": "string",
          "format": "date-time",
          "description": "The time the session ended."
        },
        "errorCount": {
          "type": "number",
          "description": "The number of errors the student made during the session."
        },
        "summary": {
          "type": "string",
          "description": "A summary of the session."
        },
        "transcript": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": {
                "type": "string",
                "enum": ["user", "model"]
              },
              "text": {
                "type": "string"
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              }
            },
            "required": ["role", "text", "timestamp"]
          },
          "description": "The chat transcript of the session."
        }
      },
      "required": ["userId", "studentName", "status", "startTime", "errorCount", "transcript"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/sessions/{sessionId}": {
      "schema": {
        "$ref": "#/entities/Session"
      },
      "description": "Stores tutoring sessions."
    }
  }
}
